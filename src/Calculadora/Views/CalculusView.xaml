<UserControl x:Class="Calculadora.Views.CalculusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Calculadora.Converters"
             Background="#1C1C1C" Foreground="White">
    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,6"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Cálculo &amp; Álgebra Simbólica" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <!-- Tabs estilo GeoGebra con símbolos -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" 
                    Background="Transparent" BorderThickness="0" Margin="0,0,0,10">

            <!-- TAB 1: Simbólico d/dx -->
            <TabItem Header="d/dx  Simbólico">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Text="Expresión f(x):" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}" FontSize="18" Padding="12"
                             Text="{Binding InputExpression, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBlock Text="Variable wrt:" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60" TextAlignment="Center"
                                 Text="{Binding Variable, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <!-- Botones con Notación Matemática GeoGebra -->
                    <WrapPanel Margin="0,0,0,10">
                        <Button Style="{StaticResource ActionBtn}" Command="{Binding DifferentiateCommand}">
                            <TextBlock><Run Text="d/d" /><Run Text="{Binding Variable, Mode=OneWay}" /><Run Text=" Derivar" /></TextBlock>
                        </Button>
                        <Button Content="S(x) Simplificar" Style="{StaticResource SecondaryBtn}" Command="{Binding SimplifyCommand}"/>
                        <Button Content="(x+a)ⁿ Expandir" Style="{StaticResource SecondaryBtn}" Command="{Binding ExpandCommand}"/>
                        <Button Content="📊 Graficar f(x)" Style="{StaticResource SecondaryBtn}" Command="{Binding SendToGraphCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </TabItem>

            <!-- TAB 2: Integrales ∫ dx -->
            <TabItem Header="∫ dx  Integrales">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Text="Función a integrar f(x):" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}" FontSize="18" Padding="12"
                             Text="{Binding InputExpression, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="a (inferior) =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1" Style="{StaticResource InputField}" TextAlignment="Center"
                                 Text="{Binding IntegralLowerBound, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Column="2" Text="b (superior) =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="15,0,8,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource InputField}" TextAlignment="Center"
                                 Text="{Binding IntegralUpperBound, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Column="4" Text="Método:" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="15,0,8,0"/>
                        <ComboBox Grid.Column="5" SelectedItem="{Binding IntegralMethod}"
                                  Background="#2C2C2E" Foreground="White" FontSize="14" Padding="8">
                            <ComboBoxItem Content="Simpson (1/3)"/>
                            <ComboBoxItem Content="Trapecio"/>
                        </ComboBox>
                    </Grid>

                    <Button Content="∫ₐᵇ f(x)dx Integrar" Style="{StaticResource ActionBtn}" Command="{Binding IntegrateCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>

            <!-- TAB 3: Ecuaciones f(x)=0 -->
            <TabItem Header="f(x)=0  Ecuaciones">
                <StackPanel Margin="0,15,0,0">
                    <!-- Newton-Raphson -->
                    <TextBlock Text="Resolución Numérica de Raíces: f(x) = 0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <TextBlock Text="Ecuación f(x) = 0:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                    <TextBox Style="{StaticResource InputField}" FontSize="18" Padding="12"
                             Text="{Binding InputExpression, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                        <TextBlock Text="Semilla x₀ =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="80" TextAlignment="Center"
                                 Text="{Binding NewtonInitialGuess, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="f(x)=0  Buscar Raíz (Newton)" Style="{StaticResource ActionBtn}" Command="{Binding NewtonRaphsonCommand}" Margin="15,0,0,0"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Border BorderBrush="#48484A" BorderThickness="0,1,0,0" Margin="0,10,0,15"/>

                    <!-- Cuadrática -->
                    <TextBlock Text="Ecuación Polinómica Cuadrática: ax² + bx + c = 0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="a =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60" TextAlignment="Center"
                                 Text="{Binding QuadA, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="b =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="15,0,5,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60" TextAlignment="Center"
                                 Text="{Binding QuadB, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="c =" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="15,0,5,0"/>
                        <TextBox Style="{StaticResource InputField}" Width="60" TextAlignment="Center"
                                 Text="{Binding QuadC, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="x = (-b ± √Δ)/2a Resolver" Style="{StaticResource ActionBtn}" Command="{Binding SolveQuadraticCommand}" Margin="15,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Resultado / Error -->
        <Border Grid.Row="2" Background="#2C2C2E" CornerRadius="8" Padding="15">
            <StackPanel>
                <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#FF453A" TextWrapping="Wrap" Margin="0,0,0,5"/>
                <TextBlock Text="Resultado:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ResultExpression}" FontSize="20" FontFamily="Consolas" Foreground="#30D158" TextWrapping="Wrap"/>
                <WrapPanel Margin="0,10,0,0">
                    <Button Content="📊 Graficar resultado" Style="{StaticResource SecondaryBtn}" Command="{Binding SendToGraphCommand}"/>
                    <Button Content="Limpiar" Style="{StaticResource SecondaryBtn}" Background="#48484A" Foreground="#AEAEB2" Command="{Binding ClearCommand}"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
