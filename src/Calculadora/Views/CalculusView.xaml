<UserControl x:Class="Calculadora.Views.CalculusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1C1C1C" Foreground="White">
    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>

        <Style x:Key="TabBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8E8E93"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título -->
            <RowDefinition Height="Auto"/>  <!-- Sub-tabs -->
            <RowDefinition Height="*"/>     <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- Título del módulo -->
        <TextBlock Grid.Row="0" Text="Cálculo Simbólico" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <!-- Sub-tabs: Simbólico | Integrales | Ecuaciones -->
        <Border Grid.Row="1" Background="#2C2C2E" CornerRadius="8" Padding="4" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Button Content="Simbólico" Style="{StaticResource TabBtn}" 
                        Background="#0A84FF" Foreground="White"/>
                <Button Content="Integrales" Style="{StaticResource TabBtn}" IsEnabled="False"/>
                <Button Content="Ecuaciones" Style="{StaticResource TabBtn}" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <!-- Contenido principal del tab Simbólico -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Entrada -->
                <RowDefinition Height="Auto"/>  <!-- Variable -->
                <RowDefinition Height="Auto"/>  <!-- Botones de acción -->
                <RowDefinition Height="Auto"/>  <!-- Error -->
                <RowDefinition Height="*"/>     <!-- Resultado -->
            </Grid.RowDefinitions>

            <!-- Campo de entrada -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Expresión:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,5"/>
                <TextBox Text="{Binding InputExpression, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2C2C2E" Foreground="White" BorderThickness="0" 
                         Padding="12" FontSize="18" FontFamily="Consolas">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Variable de derivación -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Variable:" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Text="{Binding Variable, UpdateSourceTrigger=PropertyChanged}" 
                         Background="#2C2C2E" Foreground="White" BorderThickness="0" 
                         Padding="8" FontSize="16" Width="60" FontFamily="Consolas" TextAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Botones de acción -->
            <WrapPanel Grid.Row="2" Margin="0,0,0,15">
                <Button Content="Derivar" Style="{StaticResource ActionBtn}" Command="{Binding DifferentiateCommand}"/>
                <Button Content="Simplificar" Style="{StaticResource SecondaryBtn}" Command="{Binding SimplifyCommand}"/>
                <Button Content="Expandir" Style="{StaticResource SecondaryBtn}" Command="{Binding ExpandCommand}"/>
                <Button Content="📊 Graficar" Style="{StaticResource SecondaryBtn}" Command="{Binding SendToGraphCommand}"/>
                <Button Content="Limpiar" Style="{StaticResource SecondaryBtn}" Background="#48484A" Foreground="#AEAEB2" Command="{Binding ClearCommand}"/>
            </WrapPanel>

            <!-- Mensaje de error -->
            <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" 
                       FontSize="14" Foreground="#FF453A" Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={x:Static local:StringToVisibilityConverter.Instance}}"
                       xmlns:local="clr-namespace:Calculadora.Converters"/>

            <!-- Resultado -->
            <Border Grid.Row="4" Background="#2C2C2E" CornerRadius="8" Padding="15" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Text="Resultado:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ResultExpression}" 
                               FontSize="22" FontFamily="Consolas" Foreground="#30D158"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
