<UserControl x:Class="Calculadora.Views.MatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1C1C1C" Foreground="White">
    <UserControl.Resources>
        <Style x:Key="MatrixCell" TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#48484A"/>
            <Setter Property="Width" Value="55"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DimSpinner" TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Título -->
                <RowDefinition Height="Auto"/>  <!-- Matrices A y B -->
                <RowDefinition Height="Auto"/>  <!-- Controles -->
                <RowDefinition Height="*"/>     <!-- Resultado -->
            </Grid.RowDefinitions>

            <!-- Título -->
            <TextBlock Grid.Row="0" Text="Operaciones con Matrices" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <!-- Matrices A y B -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Matriz A -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Matriz A" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Style="{StaticResource DimSpinner}" 
                                 Text="{Binding RowsA, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="×" FontSize="14" VerticalAlignment="Center" Margin="5,0"/>
                        <TextBox Style="{StaticResource DimSpinner}" 
                                 Text="{Binding ColsA, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding MatrixA}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource MatrixCell}" 
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Matriz B -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Matriz B" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBox Style="{StaticResource DimSpinner}" 
                                 Text="{Binding RowsB, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="×" FontSize="14" VerticalAlignment="Center" Margin="5,0"/>
                        <TextBox Style="{StaticResource DimSpinner}" 
                                 Text="{Binding ColsB, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding MatrixB}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Style="{StaticResource MatrixCell}" 
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- Controles -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Operación:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,8"/>
                <WrapPanel Margin="0,0,0,10">
                    <Button Content="A + B" Style="{StaticResource ActionBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Suma" Margin="0,0,5,5"/>
                    <Button Content="A − B" Style="{StaticResource ActionBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Resta" Margin="0,0,5,5"/>
                    <Button Content="A × B" Style="{StaticResource ActionBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Multiplicación" Margin="0,0,5,5"/>
                    <Button Content="det(A)" Style="{StaticResource SecondaryBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Determinante A" Margin="0,0,5,5"/>
                    <Button Content="A⁻¹" Style="{StaticResource SecondaryBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Inversa A" Margin="0,0,5,5"/>
                    <Button Content="Aᵀ" Style="{StaticResource SecondaryBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Transpuesta A" Margin="0,0,5,5"/>
                    <Button Content="tr(A)" Style="{StaticResource SecondaryBtn}" 
                            Command="{Binding CalculateCommand}" CommandParameter="Traza A" Margin="0,0,5,5"/>
                </WrapPanel>
                <Button Content="Limpiar" Style="{StaticResource SecondaryBtn}" Command="{Binding ClearCommand}" 
                        Background="#48484A" Foreground="#AEAEB2" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- Resultado / Error -->
            <Border Grid.Row="3" Background="#2C2C2E" CornerRadius="8" Padding="15" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="14" Foreground="#FF453A" 
                               TextWrapping="Wrap" Margin="0,0,0,5"/>
                    <TextBlock Text="Resultado:" FontSize="14" Foreground="#8E8E93" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding ResultText}" FontSize="16" FontFamily="Consolas" 
                               Foreground="#30D158" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
