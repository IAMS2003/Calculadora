<UserControl x:Class="Calculadora.Views.GraphPlotterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Calculadora.Controls"
             Background="#1C1C1C" Foreground="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de Funciones (Izquierda) -->
        <Border Grid.Column="0" BorderBrush="#2C2C2E" BorderThickness="0,0,1,0" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Funciones (f(x))" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <!-- Entrada de nueva función -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewExpression, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2C2C2E" Foreground="White" BorderThickness="0" 
                             Padding="8" FontSize="14" Margin="0,0,6,0" FontFamily="Consolas">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Button Grid.Column="1" Content="+" Command="{Binding AddExpressionCommand}" 
                            Background="#0A84FF" Foreground="White" BorderThickness="0" 
                            Width="34" Height="34" FontSize="18" FontWeight="Bold" Focusable="False">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- Lista de funciones actuales con selector de color -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding Functions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C2C2E" CornerRadius="6" Padding="8,8" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Botón circular para cambiar color de trazo -->
                                    <Button Grid.Column="0" 
                                            Command="{Binding DataContext.ChangeColorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="{Binding Brush}" 
                                            BorderThickness="0" Width="18" Height="18" 
                                            Margin="0,0,8,0" Focusable="False" ToolTip="Haz clic para cambiar el color del trazo">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <!-- Expresión -->
                                    <TextBlock Grid.Column="1" Text="{Binding Expression}" FontSize="14" FontFamily="Consolas" VerticalAlignment="Center"/>

                                    <!-- Eliminar -->
                                    <Button Grid.Column="2" Content="✕" 
                                            Command="{Binding DataContext.RemoveExpressionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="#FF453A" BorderThickness="0"
                                            FontSize="12" Padding="6,2" Focusable="False"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Leyenda de ayuda -->
                <TextBlock Grid.Row="3" Text="💡 Rueda del ratón = Zoom&#10;💡 Arrastrar = Mover plano" 
                           FontSize="11" Foreground="#8E8E93" Margin="0,10,0,0" LineHeight="16"/>
            </Grid>
        </Border>

        <!-- Graficador (Derecha) -->
        <controls:GraphPlotter Grid.Column="1" Functions="{Binding Functions}" />
    </Grid>
</UserControl>
