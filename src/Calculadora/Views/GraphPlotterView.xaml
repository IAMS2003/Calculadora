<UserControl x:Class="Calculadora.Views.GraphPlotterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Calculadora.Controls"
             Background="#1C1C1C" Foreground="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Panel de Funciones (Izquierda) -->
        <Border Grid.Column="0" BorderBrush="#2C2C2E" BorderThickness="0,0,1,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Funciones (f(x))" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- Entrada de nueva función -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewExpression, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#2C2C2E" Foreground="White" BorderThickness="0" 
                             Padding="8" FontSize="14" Margin="0,0,5,0"/>
                    <Button Grid.Column="1" Content="+" Command="{Binding AddExpressionCommand}" 
                            Background="#0A84FF" Foreground="White" BorderThickness="0" 
                            Width="30" FontSize="16" FontWeight="Bold">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- Lista de funciones actuales -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding Expressions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2C2C2E" CornerRadius="4" Padding="10" Margin="0,0,0,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Utilizamos DataContext para acceder al comando del ViewModel desde la celda -->
                                    <TextBlock Grid.Column="0" Text="{Binding}" FontSize="14" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="✕" 
                                            Command="{Binding DataContext.RemoveExpressionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                            CommandParameter="{Binding}"
                                            Background="Transparent" Foreground="#FF453A" BorderThickness="0"
                                            FontSize="12" Padding="5,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Graficador (Derecha) -->
        <controls:GraphPlotter Grid.Column="1" Expressions="{Binding Expressions}" />
    </Grid>
</UserControl>
