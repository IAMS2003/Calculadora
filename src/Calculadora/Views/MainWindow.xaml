<Window x:Class="Calculadora.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Calculadora.ViewModels"
        xmlns:views="clr-namespace:Calculadora.Views"
        mc:Ignorable="d"
        Title="Calculadora Científica Avanzada" Height="600" Width="800"
        MinWidth="800" MinHeight="600"
        Background="#1C1C1C" Foreground="White"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- DataTemplates para enrutar ViewModels a Views -->
        <DataTemplate DataType="{x:Type vm:CalculatorViewModel}">
            <views:BasicCalculatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScientificViewModel}">
            <views:ScientificCalculatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GraphPlotterViewModel}">
            <views:GraphPlotterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalculusViewModel}">
            <views:CalculusView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MatrixViewModel}">
            <views:MatrixView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>

        <!-- Estilo para los botones del Sidebar -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AEAEB2"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2C2C2E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#1C1C1C" BorderBrush="#2C2C2E" BorderThickness="0,0,1,0">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="MODOS" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold" Margin="10,0,0,10"/>
                
                <Button Content="Básica" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Basic"/>
                
                <Button Content="Científica" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Scientific"/>
                
                <Button Content="Graficador 2D" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Graph"/>
                
                <Button Content="Cálculo" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Calculus"/>
                
                <Button Content="Matrices" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="Matrix"/>
                
                <Separator Background="#2C2C2E" Margin="0,15"/>
                <TextBlock Text="OTROS" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold" Margin="10,0,0,10"/>

                <Button Content="Historial" Style="{StaticResource SidebarButtonStyle}" 
                        Command="{Binding NavigateCommand}" CommandParameter="History"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#1C1C1C">
            <!-- ContentControl enruta dinámicamente el CurrentView a la DataTemplate correspondiente -->
            <ContentControl Content="{Binding CurrentView}" Margin="10"/>
        </Border>
    </Grid>
</Window>
