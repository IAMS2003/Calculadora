<Window x:Class="Calculadora.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Calculadora.ViewModels"
        xmlns:views="clr-namespace:Calculadora.Views"
        xmlns:converters="clr-namespace:Calculadora.Converters"
        mc:Ignorable="d"
        Title="Calculadora Científica Avanzada" Height="650" Width="850"
        MinWidth="700" MinHeight="550"
        Background="#1C1C1C" Foreground="White"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter" Invert="False"/>
        <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisConverter" Invert="True"/>

        <!-- DataTemplates para enrutar ViewModels a Views -->
        <DataTemplate DataType="{x:Type vm:CalculatorViewModel}">
            <views:BasicCalculatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScientificViewModel}">
            <views:ScientificCalculatorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GraphPlotterViewModel}">
            <views:GraphPlotterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalculusViewModel}">
            <views:CalculusView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MatrixViewModel}">
            <views:MatrixView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StatisticsViewModel}">
            <views:StatisticsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>

        <!-- Estilo para los botones del Sidebar -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AEAEB2"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2C2C2E"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar Width bound to ViewModel -->
            <ColumnDefinition Width="{Binding SidebarWidth, Converter={x:Static converters:NumberToGridLengthConverter.Instance}, FallbackValue=220}"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#181818" BorderBrush="#2C2C2E" BorderThickness="0,0,1,0">
            <DockPanel Margin="8,15,8,10">
                <!-- Hamburger Button at Top -->
                <Button DockPanel.Dock="Top" Command="{Binding ToggleSidebarCommand}" 
                        Style="{StaticResource SidebarButtonStyle}" HorizontalContentAlignment="Center"
                        ToolTip="Alternar barra lateral" Margin="0,0,0,15">
                    <TextBlock Text="☰" FontSize="18" FontWeight="Bold" Foreground="White"/>
                </Button>

                <StackPanel DockPanel.Dock="Top">
                    <!-- Section Title MODOS -->
                    <TextBlock Text="MODOS" Foreground="#8E8E93" FontSize="11" FontWeight="SemiBold" Margin="10,0,0,8"
                               Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisConverter}}"/>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Basic" ToolTip="Básica">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔢" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Básica" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Scientific" ToolTip="Científica">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧪" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Científica" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Graph" ToolTip="Graficador 2D">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Graficador 2D" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Calculus" ToolTip="Cálculo">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="∫" FontSize="18" FontWeight="Bold" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Cálculo" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Matrix" ToolTip="Matrices">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Matrices" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="Statistics" ToolTip="Estadística">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Estadística" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                    
                    <Separator Background="#2C2C2E" Margin="4,15"/>

                    <!-- Section Title OTROS -->
                    <TextBlock Text="OTROS" Foreground="#8E8E93" FontSize="11" FontWeight="SemiBold" Margin="10,0,0,8"
                               Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisConverter}}"/>

                    <Button Style="{StaticResource SidebarButtonStyle}" 
                            Command="{Binding NavigateCommand}" CommandParameter="History" ToolTip="Historial">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="16" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Historial" VerticalAlignment="Center"
                                       Visibility="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisConverter}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" Background="#1C1C1C">
            <!-- ContentControl enruta dinámicamente el CurrentView a la DataTemplate correspondiente -->
            <ContentControl Content="{Binding CurrentView}" Margin="10"/>
        </Border>
    </Grid>
</Window>
