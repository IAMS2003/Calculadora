<UserControl x:Class="Calculadora.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1C1C1C" Foreground="White">
    <UserControl.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Grid.Row="0" Text="Estadística &amp; Regresión de Datos" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Izquierda: Tabla de datos (X, Y) -->
            <Border Grid.Column="0" Background="#252528" CornerRadius="8" Padding="12" Margin="0,0,15,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Puntos de Datos (X, Y)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Formulario de agregar punto -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="X:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Grid.Column="1" Style="{StaticResource InputField}" Text="{Binding NewX, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource InputField}" Text="{Binding NewY, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Grid.Column="4" Content="+" Style="{StaticResource ActionBtn}" Command="{Binding AddPointCommand}" Margin="8,0,0,0" Padding="10,4"/>
                    </Grid>

                    <!-- Lista de puntos -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DataPoints}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2C2C2E" CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding X, StringFormat='X: {0:G5}'}" FontFamily="Consolas" FontSize="13"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Y, StringFormat='Y: {0:G5}'}" FontFamily="Consolas" FontSize="13"/>
                                            <Button Grid.Column="2" Content="✕" 
                                                    Command="{Binding DataContext.RemovePointCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Background="Transparent" Foreground="#FF453A" BorderThickness="0" FontSize="12" Padding="4,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Button Grid.Row="3" Content="Vaciar Tabla" Style="{StaticResource SecondaryBtn}" Command="{Binding ClearPointsCommand}" 
                            Foreground="#FF453A" Margin="0,10,0,0" HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <!-- Derecha: Resultados Estadísticos y Regresión -->
            <Border Grid.Column="1" Background="#252528" CornerRadius="8" Padding="15">
                <StackPanel>
                    <TextBlock Text="Análisis Estadístico &amp; Modelo" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <!-- Resumen descriptivo -->
                    <Border Background="#1C1C1C" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Estadísticas Descriptivas:" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding StatsSummaryText}" FontSize="15" FontFamily="Consolas" Foreground="White" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <!-- Selector de tipo de regresión -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Modelo de Regresión:" FontSize="14" Foreground="#8E8E93" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox ItemsSource="{Binding RegressionTypes}" SelectedItem="{Binding SelectedRegressionType}"
                                  Background="#1C1C1C" Foreground="White" FontSize="14" Padding="8" Width="240"/>
                    </StackPanel>

                    <!-- Ecuación calculada y R^2 -->
                    <Border Background="#1C1C1C" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Resultado del Modelo R²:" FontSize="13" Foreground="#8E8E93" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding RegressionResultText}" FontSize="16" FontFamily="Consolas" Foreground="#30D158" TextWrapping="Wrap" LineHeight="24"/>
                        </StackPanel>
                    </Border>

                    <Button Content="📊 Graficar Curva de Regresión en 2D" Style="{StaticResource ActionBtn}" Command="{Binding SendToGraphCommand}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
