<UserControl x:Class="Calculadora.Views.VirtualKeypadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#252528">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#323236"/>
            <Setter Property="Foreground" Value="#0A84FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,8"/>
            <Setter Property="Focusable" Value="False"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
        </Style>
        <Style x:Key="OpKey" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF9F0A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="NumKey" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#3A3A3C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Border Padding="6" CornerRadius="6" BorderBrush="#3A3A3C" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⌨ Teclado Matemático" FontSize="11" Foreground="#8E8E93" Margin="4,0,0,4"/>

            <UniformGrid Grid.Row="1" Rows="3" Columns="7">
                <Button Content="π" Command="{Binding AppendCommand}" CommandParameter="pi"/>
                <Button Content="e" Command="{Binding AppendCommand}" CommandParameter="e"/>
                <Button Content="x²" Command="{Binding AppendCommand}" CommandParameter="^2"/>
                <Button Content="xⁿ" Command="{Binding AppendCommand}" CommandParameter="^"/>
                <Button Content="√" Command="{Binding AppendCommand}" CommandParameter="sqrt("/>
                <Button Content="(" Command="{Binding AppendCommand}" CommandParameter="("/>
                <Button Content=")" Command="{Binding AppendCommand}" CommandParameter=")"/>

                <Button Content="sin" Command="{Binding AppendFunctionCommand}" CommandParameter="sin"/>
                <Button Content="cos" Command="{Binding AppendFunctionCommand}" CommandParameter="cos"/>
                <Button Content="tan" Command="{Binding AppendFunctionCommand}" CommandParameter="tan"/>
                <Button Content="ln" Command="{Binding AppendFunctionCommand}" CommandParameter="ln"/>
                <Button Content="log" Command="{Binding AppendFunctionCommand}" CommandParameter="log"/>
                <Button Content="|" Command="{Binding AppendCommand}" CommandParameter="abs("/>
                <Button Content="!" Command="{Binding AppendCommand}" CommandParameter="!"/>

                <Button Content="+" Style="{StaticResource OpKey}" Command="{Binding AppendCommand}" CommandParameter="+"/>
                <Button Content="−" Style="{StaticResource OpKey}" Command="{Binding AppendCommand}" CommandParameter="-"/>
                <Button Content="×" Style="{StaticResource OpKey}" Command="{Binding AppendCommand}" CommandParameter="*"/>
                <Button Content="÷" Style="{StaticResource OpKey}" Command="{Binding AppendCommand}" CommandParameter="/"/>
                <Button Content="x" Style="{StaticResource NumKey}" Command="{Binding AppendCommand}" CommandParameter="x"/>
                <Button Content="=" Style="{StaticResource OpKey}" Command="{Binding EvaluateCommand}"/>
                <Button Content="C" Style="{StaticResource NumKey}" Command="{Binding ClearCommand}"/>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
